<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <CheckBox
        android:id="@+id/chkRememberVolume"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/remember_volume"
        android:textColor="@color/meditation_text"
        android:layout_marginBottom="8dp" />

    <CheckBox
        android:id="@+id/chkPlayAsAlarm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/play_as_alarm"
        android:textColor="@color/meditation_text"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/time_format"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/meditation_text"
        android:layout_marginBottom="4dp" />

    <RadioGroup
        android:id="@+id/radioTimeFormat"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <RadioButton
            android:id="@+id/radio24h"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/time_format_24h"
            android:textColor="@color/meditation_text"
            android:layout_marginEnd="16dp" />

        <RadioButton
            android:id="@+id/radio12h"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/time_format_12h"
            android:textColor="@color/meditation_text" />
    </RadioGroup>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/theme_mode"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/meditation_text"
        android:layout_marginBottom="4dp" />

    <RadioGroup
        android:id="@+id/radioThemeMode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <RadioButton
            android:id="@+id/radioThemeLight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/theme_light"
            android:textColor="@color/meditation_text"
            android:layout_marginEnd="8dp" />

        <RadioButton
            android:id="@+id/radioThemeDark"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/theme_dark"
            android:textColor="@color/meditation_text"
            android:layout_marginEnd="8dp" />

        <RadioButton
            android:id="@+id/radioThemeSystem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/theme_system"
            android:textColor="@color/meditation_text" />
    </RadioGroup>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Vibration Settings"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/meditation_text"
        android:layout_marginBottom="4dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Executions"
            android:textColor="@color/meditation_text"
            android:layout_marginEnd="8dp" />

        <EditText
            android:id="@+id/editVibExecutions"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:textColor="@color/meditation_text"
            android:text="2" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Duration (ms)"
            android:textColor="@color/meditation_text"
            android:layout_marginEnd="8dp" />

        <EditText
            android:id="@+id/editVibDuration"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:textColor="@color/meditation_text"
            android:text="500" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gap (ms)"
            android:textColor="@color/meditation_text"
            android:layout_marginEnd="8dp" />

        <EditText
            android:id="@+id/editVibGap"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:textColor="@color/meditation_text"
            android:text="1000" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnTestVibration"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Test Vibration"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_marginBottom="16dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnExportDb"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/export_database"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_marginBottom="8dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnImportDb"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/import_database"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

</LinearLayout>

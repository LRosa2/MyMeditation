<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:hint="@string/chains_min_minutes">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editChainMin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnShowChains"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/show_chains"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerChains"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:scrollbars="vertical"
        android:fadeScrollbars="false" />

    <TextView
        android:id="@+id/txtEmptyChains"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/no_chains"
        android:textSize="14sp"
        android:textColor="@color/meditation_text"
        android:gravity="center"
        android:padding="8dp"
        android:visibility="gone" />

</LinearLayout>
